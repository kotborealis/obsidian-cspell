{
	"name": "obsidian-cspell",
	"version": "1.3.6",
	"description": "Obsidian plugin with cspell commands and live misspelling highlights.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:e2e": "npm run build && wdio run wdio.conf.mts"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/language": "^6.12.1",
		"@eslint/js": "9.30.1",
		"@lezer/common": "^1.5.1",
		"@types/node": "^20.19.33",
		"@wdio/cli": "^9.24.0",
		"@wdio/globals": "^9.23.0",
		"@wdio/local-runner": "^9.24.0",
		"@wdio/mocha-framework": "^9.24.0",
		"@wdio/spec-reporter": "^9.24.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"mocha": "^10.8.2",
		"obsidian-launcher": "^2.3.2",
		"tslib": "2.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18",
		"wdio-obsidian-reporter": "^2.3.2",
		"wdio-obsidian-service": "^2.3.2"
	},
	"dependencies": {
		"@codemirror/language": "^6.10.0",
		"@codemirror/state": "^6.4.1",
		"@codemirror/view": "^6.28.2",
		"@cspell/dict-en_us": "^4.4.29",
		"@cspell/dict-ru_ru": "^2.3.2",
		"@lezer/common": "^1.2.0",
		"cspell-lib": "^8.0.0",
		"obsidian": "latest"
	}
}
